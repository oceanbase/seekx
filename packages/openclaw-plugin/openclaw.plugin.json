{
  "id": "seekx",
  "name": "seekx",
  "description": "Local-first hybrid search memory backend: BM25 + vector + rerank + CJK",
  "version": "0.1.0",
  "kind": "memory",
  "skills": ["skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dbPath": {
        "type": "string"
      },
      "paths": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "path"],
          "properties": {
            "name": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "pattern": {
              "type": "string"
            }
          }
        }
      },
      "apiKey": {
        "type": "string"
      },
      "baseUrl": {
        "type": "string"
      },
      "embedModel": {
        "type": "string"
      },
      "rerankModel": {
        "type": "string"
      },
      "expandModel": {
        "type": "string"
      },
      "searchLimit": {
        "type": "number"
      },
      "refreshIntervalMs": {
        "type": "number"
      },
      "includeOpenClawMemory": {
        "type": "boolean"
      },
      "citations": {
        "type": "string",
        "enum": ["auto", "on", "off"]
      },
      "searchTimeoutMs": {
        "type": "number"
      },
      "autoRecall": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "maxResults": {
            "type": "number"
          },
          "minScore": {
            "type": "number"
          },
          "maxChars": {
            "type": "number"
          },
          "minQueryLength": {
            "type": "number"
          }
        }
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "label": "API key",
      "sensitive": true,
      "help": "API key for embedding/reranking/expansion. Inherits from ~/.seekx/config.yml if unset."
    },
    "baseUrl": {
      "label": "API base URL",
      "placeholder": "https://api.siliconflow.cn/v1",
      "help": "OpenAI-compatible API base URL."
    },
    "embedModel": {
      "label": "Embedding model",
      "placeholder": "BAAI/bge-large-zh-v1.5"
    },
    "rerankModel": {
      "label": "Reranking model",
      "placeholder": "BAAI/bge-reranker-v2-m3",
      "help": "Omit to disable reranking."
    },
    "expandModel": {
      "label": "Query expansion model",
      "placeholder": "Qwen/Qwen3-8B",
      "help": "Omit to disable query expansion."
    },
    "citations": {
      "label": "Citations mode",
      "help": "Append Source: path#line footer to search snippets. \"auto\" (default) or \"on\" enables it; \"off\" suppresses the footer while still passing the path internally."
    },
    "searchTimeoutMs": {
      "label": "Search timeout (ms)",
      "help": "Maximum time for a single memory_search call. Default 8000ms. Set to 0 to disable."
    },
    "autoRecall": {
      "label": "Auto recall",
      "help": "Proactively search seekx before prompt build for recall-style user requests, then inject a small set of high-confidence matches into the prompt."
    }
  }
}
