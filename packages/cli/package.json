{
  "name": "seekx",
  "version": "0.3.0",
  "description": "CLI for hybrid local search: BM25 + vector embeddings, incremental indexing, and realtime file watch. Requires Bun.",
  "keywords": [
    "seekx",
    "search",
    "cli",
    "hybrid-search",
    "bm25",
    "vector-search",
    "embeddings",
    "sqlite",
    "local-first",
    "rag",
    "markdown",
    "knowledge-base",
    "oceanbase"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/oceanbase/seekx.git",
    "directory": "packages/cli"
  },
  "files": [
    "bin",
    "src"
  ],
  "bin": {
    "seekx": "./bin/seekx.js"
  },
  "scripts": {
    "test": "bun test test/program.test.ts && bun test test/version.test.ts && bun test test/formatter.test.ts && bun test test/cli.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/seekx.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "seekx-core": "^0.3.0",
    "commander": "^13.1.0",
    "@inquirer/prompts": "^7.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
